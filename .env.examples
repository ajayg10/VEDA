# Provider: groq | ollama
LLM_PROVIDER=groq

# Groq → get free key at console.groq.com (no credit card)
# Ollama → set to any non-empty string, e.g. "ollama"
LLM_API_KEY=your-groq-key-here

# Groq models (free tier):
#   llama-3.3-70b-versatile   ← best quality, use this
#   llama3-8b-8192            ← faster, lighter
#   mixtral-8x7b-32768        ← good for structured output
#
# Ollama models (local, pull first with: ollama pull <model>):
#   llama3.2        ← good balance
#   qwen2.5:7b      ← excellent at structured JSON output
#   mistral         ← reliable for structured tasks
LLM_MODEL=llama-3.3-70b-versatile